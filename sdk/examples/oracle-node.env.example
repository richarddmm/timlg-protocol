# ── TIMLG Oracle Operator — Environment Configuration ─────────────────────────
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains private key paths.
#
# cp .env.example .env

# ─── Required ──────────────────────────────────────────────────────────────────

# Path to your Oracle keypair JSON (the pubkey must be registered on-chain via set_oracle_pubkey).
# Generate: solana-keygen new -o ~/.config/timlg/oracle/id.json
ORACLE_KEYPAIR_PATH=~/.config/timlg/oracle/id.json

# Path to a funded keypair that pays transaction fees (can be the same as ORACLE if desired).
RELAYER_KEYPAIR_PATH=~/.config/solana/id.json

# ─── Optional — defaults shown ────────────────────────────────────────────────

# Solana RPC endpoint. Use a private RPC for production.
RPC_URL=https://api.devnet.solana.com

# NIST Beacon chain index (Chain 2 = default production chain).
NIST_CHAIN_INDEX=2

# How many seconds to wait between pulse-check cycles in watch mode.
OPERATOR_TICK_SEC=15

# How many recent rounds to scan for pending pulses per tick.
OPERATOR_LOOKBACK=30
